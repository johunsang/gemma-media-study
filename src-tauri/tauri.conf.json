{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YouTube Gemma Analyzer",
  "version": "0.1.0",
  "identifier": "com.local.youtube-gemma-analyzer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YouTube Gemma Analyzer",
        "width": 1120,
        "height": 780,
        "minWidth": 780,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
